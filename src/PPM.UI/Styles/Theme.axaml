<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ============================================================= -->
    <!-- Paleta centralizada de PPM. Tokens semánticos: ninguna vista  -->
    <!-- debe usar colores sueltos, siempre referenciar estos brushes. -->
    <!-- ============================================================= -->

    <!-- Colores base -->
    <Color x:Key="BackgroundColor">#F4F6F8</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SidebarColor">#1E2A3A</Color>
    <Color x:Key="TextPrimaryColor">#1B1F24</Color>
    <Color x:Key="TextSecondaryColor">#626C7A</Color>
    <Color x:Key="AccentColor">#2F6FED</Color>
    <Color x:Key="PositiveColor">#1F9254</Color>
    <Color x:Key="DangerColor">#D64545</Color>
    <Color x:Key="WarningColor">#C77A0A</Color>
    <Color x:Key="BorderColor">#E2E6EB</Color>

    <!-- Brushes semánticos -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="PositiveBrush" Color="{StaticResource PositiveColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <!-- Texto sobre superficies oscuras/de color -->
    <SolidColorBrush x:Key="OnColorBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="OnColorMutedBrush" Color="#C7D2E0" />
</ResourceDictionary>
