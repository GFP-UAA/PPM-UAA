<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PPM.UI.ViewModels"
             xmlns:dto="clr-namespace:PPM.Application.DTOs;assembly=PPM.Application"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="600"
             x:Class="PPM.UI.Views.CreditCardsView"
             x:DataType="vm:CreditCardsViewModel">
    <Grid Margin="28" RowDefinitions="Auto,Auto,*">
        <TextBlock Grid.Row="0" Text="Tarjetas de crédito" FontSize="26" FontWeight="Bold" Margin="0,0,0,12"
                   Foreground="{StaticResource TextPrimaryBrush}" />

        <StackPanel Grid.Row="1" Spacing="2" Margin="0,0,0,10">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource PositiveBrush}" TextWrapping="Wrap"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <Grid Grid.Row="2" ColumnDefinitions="*,380">
            <!-- Lista -->
            <Border Grid.Column="0" Margin="0,0,16,0" Padding="12" CornerRadius="12"
                    Background="{StaticResource SurfaceBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="2*,*,*" Margin="4,0,4,6">
                        <TextBlock Grid.Column="0" Text="Tarjeta" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="Deuda" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Grid.Column="2" Text="Pago mín." FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
                    </Grid>
                    <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="dto:CreditCardDto">
                                <Grid ColumnDefinitions="2*,*,*">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding MonthlyInterestRate, StringFormat='Tasa {0}% mensual'}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding CurrentDebt, Converter={StaticResource Guarani}}" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding MinimumPayment, Converter={StaticResource Guarani}}" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Panel derecho -->
            <Border Grid.Column="1" Padding="16" CornerRadius="12"
                    Background="{StaticResource SurfaceBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                <ScrollViewer>
                    <StackPanel Spacing="8">
                        <TextBlock Text="Detalle de la tarjeta" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Nombre" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding Name}" />
                        <TextBlock Text="Límite disponible (₲)" Foreground="{StaticResource TextSecondaryBrush}" />
                        <NumericUpDown Minimum="0" Increment="100000" FormatString="N0" Value="{Binding AvailableBalance}" />
						<TextBlock Text="Deuda inicial (₲) — solo al crear"   Foreground="{StaticResource TextSecondaryBrush}" />
                        <NumericUpDown Minimum="0" Increment="100000" FormatString="N0" Value="{Binding InitialBalance}" IsEnabled="{Binding IsNew}" />
                        <TextBlock Text="Tasa de interés mensual (%)" Foreground="{StaticResource TextSecondaryBrush}" />
                        <NumericUpDown Minimum="0" Increment="0.5" FormatString="0.####" Value="{Binding MonthlyInterestRate}" />
                        <TextBlock Text="Día de cierre (1-31)" Foreground="{StaticResource TextSecondaryBrush}" />
                        <NumericUpDown Minimum="1" Maximum="31" Increment="1" FormatString="0" Value="{Binding ClosingDay}" />
                        <TextBlock Text="El saldo se calcula automáticamente a partir de los movimientos. Pago mínimo: 5% fijo." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />

                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                            <Button Content="Nueva" Command="{Binding NewCommand}" />
                            <Button Content="Guardar" Classes="accent" Command="{Binding SaveCommand}" IsEnabled="{Binding !IsLoading}" />
                            <Button Content="Eliminar" Command="{Binding DeleteCommand}" IsEnabled="{Binding IsEditing}" />
                        </StackPanel>

                        <!-- Acciones sobre la tarjeta seleccionada -->
                        <StackPanel Spacing="10" Margin="0,10,0,0" IsVisible="{Binding IsEditing}">
                            <TextBlock Text="{Binding ActionMessage}" TextWrapping="Wrap" Foreground="{StaticResource AccentBrush}"
                                       IsVisible="{Binding ActionMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                            <!-- Registrar consumo -->
                            <Border Padding="12" CornerRadius="8" Background="{StaticResource BackgroundBrush}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Registrar consumo" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <NumericUpDown Minimum="0" Increment="50000" FormatString="N0" Value="{Binding ConsumoAmount}" />
                                    <TextBox Watermark="Descripción" Text="{Binding ConsumoDescription}" />
                                    <Button Content="Agregar consumo" Command="{Binding RegisterConsumoCommand}" IsEnabled="{Binding !IsLoading}" />
                                </StackPanel>
                            </Border>

                            <!-- Registrar pago -->
                            <Border Padding="12" CornerRadius="8" Background="{StaticResource BackgroundBrush}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Registrar pago" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <NumericUpDown Minimum="0" Increment="50000" FormatString="N0" Value="{Binding PagoAmount}" />
                                    <TextBox Watermark="Descripción" Text="{Binding PagoDescription}" />
                                    <Button Content="Agregar pago" Command="{Binding RegisterPagoCommand}" IsEnabled="{Binding !IsLoading}" />
                                </StackPanel>
                            </Border>

                            <!-- Pago de cierre -->
                            <Border Padding="12" CornerRadius="8" Background="{StaticResource BackgroundBrush}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Pago de cierre" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Saldo actual" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedItem.CurrentDebt, Converter={StaticResource Guarani}}" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Interés proyectado" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedItem.MonthlyInterest, Converter={StaticResource Guarani}}" Foreground="{StaticResource WarningBrush}" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Pago mínimo" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedItem.MinimumPayment, Converter={StaticResource Guarani}}" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </Grid>
                                    <NumericUpDown Minimum="0" Increment="50000" FormatString="N0" Value="{Binding ClosingAmount}" />
                                    <Button Content="Procesar cierre" Classes="accent" Command="{Binding ProcessClosingCommand}" IsEnabled="{Binding !IsLoading}" />
                                </StackPanel>
                            </Border>

                            <!-- Libro de movimientos -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Movimientos" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <ItemsControl ItemsSource="{Binding Movements}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="dto:CardMovementDto">
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextPrimaryBrush}" />
                                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                               Text="{Binding Date, StringFormat='{}{0:dd/MM/yyyy}'}" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold"
                                                           Text="{Binding Amount, Converter={StaticResource Guarani}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Historial de cierres -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Historial de cierres" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <ItemsControl ItemsSource="{Binding Payments}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="dto:CreditCardPaymentDto">
                                            <Grid ColumnDefinitions="*,*" Margin="0,3">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding PaidAmount, Converter={StaticResource Guarani}}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                                    <TextBlock Text="{Binding PaymentDate, StringFormat='{}{0:dd/MM/yyyy}'}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding InterestApplied, Converter={StaticResource Guarani}, StringFormat='Interés: {0}'}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <TextBlock Text="{Binding DebtAfterPayment, Converter={StaticResource Guarani}, StringFormat='Saldo: {0}'}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
